{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 30,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "ninja-gfortran",
            "displayName": "Ninja Multi-Config (gfortran + clang)",
            "description": "Default: gfortran + clang/clang++ (GNU ABI), outputs to build/ and bin/",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build",
            "toolchainFile": "${sourceDir}/cmake/gfortran-toolchain.cmake"
        },
        {
            "name": "ninja-ifx",
            "displayName": "Ninja Multi-Config (ifx + MSVC)",
            "description": "ifx + cl.exe (MSVC ABI), outputs to build-ifx/ and bin-ifx/",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build-ifx",
            "cacheVariables": {
                "CMAKE_Fortran_COMPILER": "ifx",
                "CMAKE_C_COMPILER": "cl",
                "CMAKE_CXX_COMPILER": "cl"
            }
        },
        {
            "name": "ninja-ifx-clangcl",
            "displayName": "Ninja Multi-Config (ifx + clang-cl)",
            "description": "ifx + clang-cl (MSVC ABI), outputs to build-ifx/ and bin-ifx/",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build-ifx",
            "cacheVariables": {
                "CMAKE_Fortran_COMPILER": "ifx",
                "CMAKE_C_COMPILER": "clang-cl",
                "CMAKE_CXX_COMPILER": "clang-cl"
            }
        },
        {
            "name": "ninja-unix",
            "displayName": "Ninja Multi-Config (Linux/macOS)",
            "description": "Default for non-Windows platforms",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build"
        }
    ]
}
